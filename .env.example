# Copy this file to `.env` and fill in the values you need.
# `cse` reads nothing from this file directly — these are the standard
# environment variables each cloud SDK already honours.

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_PROFILE=
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# ─── Azure ────────────────────────────────────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# AZURE_CLIENT_CERTIFICATE_PATH=
AZURE_SUBSCRIPTION_ID=

# ─── GCP ──────────────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# ─── cse runtime tuning (optional, prefix CSE_) ───────────────────────────────
# CSE_MAX_CONCURRENCY=10
# CSE_TIMEOUT_S=120
